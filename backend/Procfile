web: echo "=== Seeding static assets into volume ===" && cp -rn storage/seed-uploads/* public/assets/ 2>/dev/null && echo "Seeded $(ls storage/seed-uploads/images/ 2>/dev/null | wc -l) static files" && until php artisan tinker --execute="DB::connection()->getPdo();" 2>/dev/null; do echo "Waiting for database..."; sleep 5; done && php artisan railway:fix-migrations && php artisan migrate --force && php artisan version:sync && php artisan serve --host=0.0.0.0 --port=$PORT
worker: until php artisan tinker --execute="DB::connection()->getPdo();" 2>/dev/null; do echo "Waiting for database..."; sleep 5; done && php artisan schedule:work
